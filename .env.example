# OpenAI API key — get from platform.openai.com/api-keys
OPENAI_API_KEY=

# OpenAI org ID — optional, needed for enterprise accounts
# OPENAI_ORG_ID=

# Anthropic API key — get from console.anthropic.com (needed for Claude models)
ANTHROPIC_API_KEY=

# Calendly MCP token — either a PAT or an OAuth token from setup_auth.py
CALENDLY_MCP_TOKEN=
CALENDLY_MCP_REFRESH_TOKEN=
